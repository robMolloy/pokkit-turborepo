{
  "name": "@repo/pokkit-auth",
  "version": "0.0.0",
  "exports": {
    ".": "./index.ts",
    "./styles.css": "./dist/styles.css"
  },
  "license": "MIT",
  "scripts": {
    "lint": "eslint \"**/*.ts\"",
    "test": "vitest",
    "tsc": "cd ../.. && packages/pokkit-auth/node_modules/.bin/tsc --project packages/pokkit-auth/tsconfig.json --noemit --watch",
    "db:init-dev": "cd pocketbase && go mod init app-db && go mod tidy",
    "db:serve-dev": "cd pocketbase && go run . serve --http=\"0.0.0.0:8090\"",
    "db:build": "cd pocketbase && go build && mkdir -p builds && mv app-db builds/app-db",
    "db:build:on-change-to-dev": "cd pocketbase && npx nodemon --delay 1 --watch pocketbase/app-db/main.go --exec \"pnpm run db:build\"",
    "css-build": "tailwindcss -i ./styles.css -o ./dist/styles.css --watch"
  },
  "dependencies": {
    "@repo/pokkit-components": "workspace:^",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "pocketbase": "^0.26.8",
    "radix-ui": "^1.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/pokkit-testing": "workspace:^",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "eslint": "^8.57.0",
    "eventsource": "^4.1.0",
    "fs-extra": "^11.3.3",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.2",
    "vite": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
